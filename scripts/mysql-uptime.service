[Unit]
Description=Continuous MySQL Uptime Monitor
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=opc
Environment=HOME=/home/opc
WorkingDirectory=/home/opc
ExecStart=/usr/bin/python3 /usr/local/bin/mysql-uptime.py
Restart=always
RestartSec=10
KillMode=control-group
TimeoutStopSec=30
Nice=10

[Install]
WantedBy=multi-user.target
