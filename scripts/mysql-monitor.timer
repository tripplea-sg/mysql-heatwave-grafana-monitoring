[Unit]
Description=Run MySQL Monitor every minute

[Timer]
# *:0/1 means 'every minute' (0, 1, 2...)
OnCalendar=*:0/1
# Crucial: Forces systemd to be precise instead of delaying for power saving
AccuracySec=1s
# Ensures missed runs (during downtime) execute immediately on boot
Persistent=true
Unit=mysql-monitor.service

[Install]
WantedBy=timers.target

