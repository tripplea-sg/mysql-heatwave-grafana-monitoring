GRAFANA_URL="http://localhost:3000"
USER="admin"
DASHBOARD_DIR="/home/opc"

read -s -p "Enter Grafana admin password: " PASSWORD
echo

if [ -z "$PASSWORD" ]; then
    echo "Password cannot be empty. Exiting."
    exit 1
fi

FILES=(
"mysql-monitor-configuration.json"
"mysql-monitor-instance-dashboard.json"
"mysql-monitor-heatwave-dashboard.json"
"mysql-global-variable.json"
"mysql-group-replication.json"
"mysql-monitor-security.json"
)

for FILE in "${FILES[@]}"; do
    FULL_PATH="$DASHBOARD_DIR/$FILE"

    if [ ! -f "$FULL_PATH" ]; then
        echo "File not found: $FULL_PATH"
        continue
    fi

    echo "Deploying $FILE..."

    curl -s -u "$USER:$PASSWORD" \
        -X POST "$GRAFANA_URL/api/dashboards/db" \
        -H "Content-Type: application/json" \
        -d "{
            \"dashboard\": $(cat "$FULL_PATH"),
            \"overwrite\": true
        }"

    echo
    echo "$FILE deployed."
done

echo "Dashboard deployment finished."
